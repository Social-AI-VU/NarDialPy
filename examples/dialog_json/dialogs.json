  {
    "id": "place_in_nature",
    "type": "chitchat",
    "theme": "nature",
    "topics": ["sea", "forest", "mountains", "beach", "nature"],
    "dependencies": ["greeting"],
    "moves": [
      { "type": "say", "text": "By the way, do you know what I’ve read?" },
      { "type": "say", "text": "Apparently people get happy from nature." },
      { "type": "say", "text": "From swimming in the sea, or taking a walk in the forest, or climbing in the mountains, or lounging on the beach." },
      {
        "type": "ask_options",
        "text": "Which place in nature would you most like to go to right now? The sea, the forest, the mountains, or the beach?",
        "options": ["sea", "forest", "mountains", "beach"],
        "set_variable": "favorite_nature_place",
        "add_interest_from_variable": true,
        "outcomes": { "sea": "sea", "forest": "forest", "mountains": "mountains", "beach": "beach" },
        "default_outcome": "fail_place"
      },
      {
        "type": "branch",
        "on": "outcome",
        "cases": {
          "sea": [
            { "type": "say", "text": "I also really love the sea!" },
            { "type": "say", "text": "If you hold a shell to your ear, it's just like you hear the sea." }
          ],
          "forest": [
            { "type": "say", "text": "I also really like going to the forest!" }
          ],
          "mountains": [
            { "type": "say", "text": "How exciting! From the top of a mountain you have the most beautiful view over the world." }
          ],
          "beach": [
            { "type": "say", "text": "I’d really like to go there for real sometime!" }
          ],
          "fail_place": [
            { "type": "say", "text": "I think I would most like to go to the sea." }
          ]
        }
      },
      { "type": "say", "text": "Okay, let’s talk about something else!" }
        ]
  },
