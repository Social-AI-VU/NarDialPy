    },
    {
      "role": "robot",
      "type": "say",
      "text": "I was dreaming, but nothing happened."
    },
    {
      "role": "system",
      "type": "dialog_end",
      "dialog_id": "dream_on_demand_2"
    },
    {
      "role": "system",
