      },
      { "type": "timed_wait", "duration_seconds": 10.0 },
      { "type": "say", "text": "Now, I will display an orange." },
      {
        "type": "show_image",
        "src": "assets/images/orange.jpg"
      },
      { "type": "timed_wait", "duration_seconds": 10.0 },
      { "type": "say", "text": "Now, I will display a banana." },
      {
        "type": "show_image",
        "src": "assets/images/banana.jpg"
      },
      { "type": "timed_wait", "duration_seconds": 10.0 },
      {"type": "say", "text": "Finally, I will play a video" },
      {
        "type": "show_video",
