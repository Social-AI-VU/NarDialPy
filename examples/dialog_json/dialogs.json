  {
    "id": "robot_want_to_be",
    "type": "chitchat",
    "theme": "robots",
    "topics": ["robots", "identity"],
    "dependencies": ["greeting"],
    "moves": [
      { "type": "say", "text": "You know, %first_name%." },
      { "type": "say", "text": "Yesterday I was thinking about seeing you again today." },
      { "type": "say", "text": "And that today I get to learn from you again about human things." },
      { "type": "say", "text": "And then I suddenly wondered:" },
      {
        "type": "ask_yesno",
        "text": "Would you ever want to be a robot?",
        "set_variable": "wants_to_be_robot",
        "add_interest": "robots",
        "outcomes": { "yes": "yes", "no": "no", "dontknow": "dontknow" },
        "default_outcome": "no"
      },
      {
        "type": "branch",
        "on": "outcome",
        "cases": {
          "yes": [
            { "type": "say", "text": "Bizarre!" },
            {
              "type": "ask_open",
              "text": "Why would you want to be a robot?",
              "outcomes": { "*": "open_answer" },
              "default_outcome": "dontknow"
            },
            {
              "type": "branch",
              "on": "outcome",
              "cases": {
                "open_answer": [
                  { "type": "say", "text": "I really like hearing that!" },
                  {
                    "type": "ask_yesno",
                    "text": "May I also tell other robots about that?",
                    "outcomes": { "yes": "yes2" },
                    "default_outcome": "no2"
                  },
                  {
                    "type": "branch",
                    "on": "outcome",
                    "cases": {
                      "yes2": [
                        { "type": "say", "text": "Hooray! Just a moment." },
                        { "type": "say", "text": "I passed it on to them via wifi." },
                        { "type": "say", "text": "And lots of robots say thank you, dear first_name." }
                      ],
                      "no2": [
                        { "type": "say", "text": "Alright, then I'll keep your sweet words just for myself." },
                        { "type": "say", "text": "Thank you, dear first_name." }
                      ]
                    }
                  }
                ],
                "dontknow": [
                  { "type": "say", "text": "That's okay, sometimes I don't know either." }
                ]
              }
            }
          ],
          "no": [
            { "type": "say", "text": "Well, you don't know what you're missing!" },
            { "type": "say", "text": "But of course, I don't know what it's like to be human either." },
            { "type": "say", "text": "Maybe that actually is more fun." },
            { "type": "say", "text": "But I don't think I'll ever find out!" }
          ],
          "dontknow": [
            { "type": "say", "text": "That's okay, sometimes I don't know either." }
          ]
        }
      }
        ]
  },
