        },
        {
          "role": "robot",
          "type": "say",
          "text": "You know, first_name."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Yesterday I was thinking about seeing you again today."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "And that today I get to learn from you again about human things."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "And then I suddenly wondered:"
        },
        {
          "role": "robot",
          "type": "ask_yesno",
          "text": "Would you ever want to be a robot?"
        },
        {
          "role": "user",
          "type": "answer_yesno",
          "text": "yes"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Bizarre!"
        },
        {
          "role": "robot",
          "type": "ask_open",
          "text": "Why would you want to be a robot?"
        },
        {
          "role": "user",
          "type": "answer_open",
          "text": "because I would be"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "I really like hearing that!"
        },
        {
          "role": "robot",
          "type": "ask_yesno",
          "text": "May I also tell other robots about that?"
        },
        {
          "role": "user",
          "type": "answer_yesno",
          "text": "no"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Alright, then I’ll keep your sweet words just for myself."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Thank you, dear first_name."
        },
        {
          "role": "system",
