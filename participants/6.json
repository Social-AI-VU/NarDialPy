        },
        {
          "role": "robot",
          "type": "say",
          "text": "I also really love the sea!"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "If you hold a shell to your ear, it’s just like you hear the sea."
        },
        {
          "role": "robot",
