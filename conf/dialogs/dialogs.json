      { "type": "say", "text": "So I have two lucky numbers: zero and one." },
      { "type": "say", "text": "For robots those are the most special numbers in the whole world." },
      { "type": "say", "text": "One and zero together control everything I think, and hear, and see." },
      { "type": "say", "text": "Zero is off, one is on." },
