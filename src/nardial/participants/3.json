          "type": "say",
          "text": "The sea can be so calming."
        },
        {
          "role": "robot",
          "type": "ask_open",
          "text": "What do you like most about the sea?"
        },
        {
          "role": "user",
          "type": "answer_open",
          "text": "that it's blue"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "blue are great!"
        },
        {
          "role": "system",
          "type": "dialog_end",
          "dialog_id": "talk_about_sea"
