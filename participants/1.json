        {
          "role": "system",
          "type": "dialog_start",
          "dialog_id": "robot_want_to_be"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "You know, first_name."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Yesterday I was thinking about seeing you again today."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "And that today I get to learn from you again about human things."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "And then I suddenly wondered:"
        },
        {
          "role": "robot",
          "type": "ask_yesno",
          "text": "Would you ever want to be a robot?"
        },
        {
          "role": "user",
          "type": "answer_yesno",
          "text": "yes"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Bizarre!"
        },
        {
          "role": "robot",
          "type": "ask_open",
          "text": "Why would you want to be a robot?"
        },
        {
          "role": "user",
          "type": "answer_open",
          "text": "I want to have super powers"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "I really like hearing that!"
        },
        {
          "role": "robot",
          "type": "ask_yesno",
          "text": "May I also tell other robots about that?"
        },
        {
          "role": "user",
          "type": "answer_yesno",
          "text": "yes"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Hooray! Just a moment."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "I passed it on to them via wifi."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "And lots of robots say thank you, dear first_name."
        },
        {
          "role": "system",
          "type": "dialog_end",
          "dialog_id": "robot_want_to_be"
