        },
        {
          "role": "robot",
          "type": "say",
          "text": "By the way, do you know what I’ve read?"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Apparently people get happy from nature."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "From swimming in the sea, or taking a walk in the forest, or climbing in the mountains, or lounging on the beach."
        },
        {
          "role": "robot",
          "type": "ask_options",
          "text": "Which place in nature would you most like to go to right now? The sea, the forest, the mountains, or the beach?",
          "options": [
            "sea",
            "forest",
            "mountains",
            "beach"
          ]
