          "dialog_id": "hero_can_dream_1"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Sometimes I make up entire stories when I'm turned off."
        },
        {
          "role": "robot",
          "type": "ask_options",
          "text": "What is it called when you sleep and experience all sorts of things and then suddenly wake up?",
          "options": [
            "dreaming",
            "sleeping",
            "resting"
          ]
        },
        {
          "role": "user",
          "type": "answer_options",
          "text": "dreaming"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Indeed, dreaming."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "I sometimes dream of being a robot dog with four legs."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "I can fetch and deliver letters."
        },
        {
          "role": "robot",
          "type": "say",
          "text": "What do you dream about?"
        },
        {
          "role": "robot",
          "type": "ask_yesno",
          "text": "Do you remember any of your dreams?"
        },
        {
          "role": "user",
          "type": "answer_yesno",
          "text": "no"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "I have that sometimes too!"
        },
        {
          "role": "robot",
          "type": "say",
          "text": "Then you dream something and afterwards it's gone!"
        },
        {
          "role": "system",
          "type": "dialog_end",
          "dialog_id": "hero_can_dream_1"
        },
        {
