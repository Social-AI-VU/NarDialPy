    },
    {
      "role": "robot",
      "type": "ask_open",
      "text": "What do you like most about the sea?"
    },
    {
      "role": "user",
      "type": "answer_open",
      "text": "no waves"
    },
    {
      "role": "robot",
      "type": "say",
      "text": "no waves are great!"
    },
    {
      "role": "system",
      "type": "dialog_end",
      "dialog_id": "talk_about_sea"
    },
    {
      "role": "system",
      "type": "dialog_start",
      "dialog_id": "dream_on_demand_2"
    },
    {
      "role": "robot",
      "type": "say",
      "text": "Last night, when I was powered off,"
    },
    {
      "role": "robot",
      "type": "say",
